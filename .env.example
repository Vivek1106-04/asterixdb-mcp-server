# Copy to .env (gitignored) and override any defaults you need.
# All gateway settings use the ASTERIXDB_MCP_ prefix.

# AsterixDB Cluster Controller REST base URL the gateway forwards to.
# ASTERIXDB_MCP_CC_BASE_URL=http://localhost:19002

# Optional shared secret sent as the X-Gateway-Secret header on the CC hop.
# ASTERIXDB_MCP_CC_SHARED_SECRET=

# Leading segment of the namespaced client_context_id ({session}::{tag}::{uuid}).
# ASTERIXDB_MCP_AGENT_SESSION_ID=local-session

# Egress controls.
# ASTERIXDB_MCP_MAX_TIME_MS=30000            # per-query wall-clock ceiling
# ASTERIXDB_MCP_MAX_BYTES_PER_QUERY=10485760 # max response bytes buffered from the CC
# ASTERIXDB_MCP_REQUEST_TIMEOUT_S=35.0       # httpx transport timeout for the CC hop
